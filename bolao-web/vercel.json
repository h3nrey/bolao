{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "buildCommand": "npm run build",
  "outputDirectory": "dist/bolao-web/browser",
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "https://bolao-v58y.onrender.com/$1"
    },
    {
      "src": "/((?!.*\\.).*)",
      "dest": "/index.html"
    }
  ]
}
