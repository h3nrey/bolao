{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "buildCommand": "npm run build",
  "outputDirectory": "dist/bolao-web/browser",
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "https://bolao-v58y.onrender.com/:path*"
    },
    {
      "source": "/((?!.*\\.).*)",
      "destination": "/index.html"
    }
  ]
}
